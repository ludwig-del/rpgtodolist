pipeline {
    agent any

    parameters {
        string(name: 'DOCKERHUB_NAMESPACE', defaultValue: '', description: 'Optional Docker Hub username or organization. Leave blank to deploy local images on Docker Desktop Kubernetes.')
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Image tag to deploy for both services.')
        string(name: 'K8S_NAMESPACE', defaultValue: 'eldenring', description: 'Kubernetes namespace for the application deployment.')
    }

    environment {
        REGISTRY = 'https://index.docker.io/v1/'
        REGISTRY_CRED = 'registry-credentials'
        KUBECONFIG_CRED = 'kubeconfig-prod'
        TF_IN_AUTOMATION = 'true'
    }

    options {
        timeout(time: 20, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Validate Parameters') {
            steps {
                script {
                    def namespace = params.DOCKERHUB_NAMESPACE?.trim()

                    if (namespace) {
                        env.DOCKERHUB_NAMESPACE_RESOLVED = namespace
                        env.PUSH_TO_REGISTRY = 'true'
                        env.BACKEND_IMAGE = "${namespace}/rpgtodolist-backend:${params.IMAGE_TAG}"
                        env.FRONTEND_IMAGE = "${namespace}/rpgtodolist-frontend:${params.IMAGE_TAG}"
                        echo "Using Docker Hub namespace: ${namespace}"
                    } else {
                        env.DOCKERHUB_NAMESPACE_RESOLVED = ''
                        env.PUSH_TO_REGISTRY = 'false'
                        env.BACKEND_IMAGE = "rpgtodolist-backend:${params.IMAGE_TAG}"
                        env.FRONTEND_IMAGE = "rpgtodolist-frontend:${params.IMAGE_TAG}"
                        echo 'Using local Kubernetes images from the Docker Desktop image cache.'
                    }
                }
            }
        }

        stage('Build + Test') {
            parallel {
                stage('Test Backend') {
                    agent {
                        docker {
                            image 'python:3.12-slim'
                            args '--user root'
                        }
                    }
                    steps {
                        dir('backend') {
                            sh '''
                                pip install -q -r requirements.txt pytest pytest-cov
                                pytest tests/ -v --tb=short --junitxml=test-results.xml \
                                       --cov=app --cov-report=xml:coverage.xml
                            '''
                        }
                    }
                    post {
                        always {
                            junit 'backend/test-results.xml'
                            archiveArtifacts artifacts: 'backend/coverage.xml', fingerprint: true, onlyIfSuccessful: false
                        }
                    }
                }

                stage('Test Frontend') {
                    agent {
                        docker {
                            image 'node:20-alpine'
                            args '--user root'
                        }
                    }
                    steps {
                        dir('frontend') {
                            sh '''
                                npm ci --legacy-peer-deps
                                npx react-scripts test --watchAll=false --ci --passWithNoTests
                            '''
                        }
                    }
                }
            }
        }

        stage('Docker Build + Push Image') {
            steps {
                script {
                    def backendImg = docker.build(env.BACKEND_IMAGE, '-f backend/dockerfile backend')
                    def frontendImg = docker.build(env.FRONTEND_IMAGE, '-f frontend/dockerfile frontend')

                    if (env.PUSH_TO_REGISTRY == 'true') {
                        docker.withRegistry(env.REGISTRY, env.REGISTRY_CRED) {
                            backendImg.push()
                            frontendImg.push()

                            if (params.IMAGE_TAG != 'latest') {
                                docker.image(env.BACKEND_IMAGE).push('latest')
                                docker.image(env.FRONTEND_IMAGE).push('latest')
                            }
                        }
                    } else {
                        echo 'Skipping Docker Hub push because DOCKERHUB_NAMESPACE is blank.'
                    }
                }
            }
        }

        stage('Terraform + Ansible') {
            steps {
                withCredentials([file(credentialsId: KUBECONFIG_CRED, variable: 'KUBECONFIG')]) {
                    script {
                        if (fileExists('terraform/main.tf')) {
                            if (sh(script: 'command -v terraform >/dev/null 2>&1', returnStatus: true) == 0) {
                                sh '''
                                    terraform -chdir=terraform init
                                    terraform -chdir=terraform apply -auto-approve \
                                      -var="namespace=${K8S_NAMESPACE}" \
                                      -var="kubeconfig_path=${KUBECONFIG}"
                                '''
                            } else {
                                echo 'Terraform configuration is present but terraform is not installed on this agent; skipping Terraform provision stage.'
                            }
                        } else {
                            echo 'No terraform/main.tf found in this repository; skipping Terraform provision stage.'
                        }
                    }
                }
            }
        }

        stage('Kubernetes Deploy') {
            stages {
                stage('Deploy Backend') {
                    steps {
                        withCredentials([file(credentialsId: KUBECONFIG_CRED, variable: 'KUBECONFIG')]) {
                            sh '''
                                ansible-playbook \
                                  -i ansible/backend/hosts.ini \
                                  ansible/backend/deploy_backend.yml \
                                  --extra-vars "backend_image=${BACKEND_IMAGE} kube_namespace=${K8S_NAMESPACE}"
                            '''
                        }
                    }
                }

                stage('Deploy Frontend') {
                    steps {
                        withCredentials([file(credentialsId: KUBECONFIG_CRED, variable: 'KUBECONFIG')]) {
                            sh '''
                                ansible-playbook \
                                  -i ansible/frontend/hosts.ini \
                                  ansible/frontend/deploy_frontend.yml \
                                  --extra-vars "frontend_image=${FRONTEND_IMAGE} kube_namespace=${K8S_NAMESPACE}"
                            '''
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            deleteDir()
        }
    }
}